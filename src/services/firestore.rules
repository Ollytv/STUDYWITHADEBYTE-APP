rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User root document ─────────────────────────────────────────────────
    // Only the authenticated owner can read or write their own user document.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // ── All subcollections (classes, attendance, gpaCourses, etc.) ───────
      // Strictly scoped to the document owner. No cross-user access possible.
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }

      // ── Meta subcollection (profile, settings, fcmToken) ─────────────────
      match /meta/{metaDoc} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // ── Default deny — blocks everything not explicitly matched above ───────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
