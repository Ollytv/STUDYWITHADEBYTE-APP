rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Avatar uploads ─────────────────────────────────────────────────────
    // Owner-only read/write. Max 5MB. Images only.
    // Path matches storage.ts: users/{userId}/profile.jpg
    match /users/{userId}/profile.jpg {
      allow read:  if request.auth != null
                   && request.auth.uid == userId;

      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size  < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // ── Course materials ───────────────────────────────────────────────────
    // Owner-only read/write. Max 20MB.
    // MIME allowlist: PDF and images only. No executables, scripts, or archives.
    // Path matches storage.ts: users/{userId}/materials/{materialId}_{fileName}
    match /users/{userId}/materials/{materialId} {
      allow read:  if request.auth != null
                   && request.auth.uid == userId;

      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 20 * 1024 * 1024
                   && (request.resource.contentType == 'application/pdf'
                       || request.resource.contentType.matches('image/.*'));

      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // ── Default deny — blocks all other paths ─────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
